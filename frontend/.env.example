# Canonical origin (no trailing slash). Used for metadata, sitemap, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://stpeter.vercel.app
# On Vercel (or your host), set NEXT_PUBLIC_SITE_URL in project env to your live domain so canonical URLs and JSON-LD match production.

# Public API origin for browser requests. Use the deployed Express API in production.
NEXT_PUBLIC_API_URL=http://localhost:5000

# Optional server-side proxy target for frontend/src/app/api/[...path]/route.ts.
BACKEND_URL=http://localhost:5000
