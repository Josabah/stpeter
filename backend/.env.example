NODE_ENV=development
PORT=5000

# Frontend origin used for CORS and password reset links.
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/stpeter
MONGODB_MAX_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d

# Initial admin setup. In production, set both values only while bootstrapping.
ENABLE_ADMIN_SETUP=false
ADMIN_SETUP_TOKEN=replace-with-a-one-time-setup-token

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_FILE_UPLOAD=10485760

# Email
EMAIL_SERVICE=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=

# API protection
JSON_BODY_LIMIT=1mb
PUBLIC_WRITE_RATE_LIMIT=20
AUTH_RATE_LIMIT=10
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Local fallback is mongodb://127.0.0.1:27017/stpeter when omitted in development.
MONGODB_URI=mongodb://127.0.0.1:27017/stpeter

# Development fallback values are set in src/server.js when omitted.
JWT_SECRET=change-this-secret
JWT_EXPIRE=7d

# Required for gallery uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_FILE_UPLOAD=10000000

# Required for contact form email notifications.
EMAIL_SERVICE=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
